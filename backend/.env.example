# bustaTv Backend Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=sqlite:///./bustaTv.db

# API Security
# Change this to a strong random string in production
SECRET_API_KEY=bustatv-dev-secret-key-changeme

# HLS Stream Proxy Configuration
# Backend URL used by the stream proxy to rewrite segment URLs
# Local: http://localhost:8000
# Production (Render): https://localtv.onrender.com
BACKEND_URL=http://localhost:8000

# Server Configuration (optional)
# HOST=0.0.0.0
# PORT=8000
# DEBUG=True
